#
# digit class
#
digit   <zero>;...;<nine>

#
# xdigit class
#
xdigit  <zero>;...;<nine>;\
        <A>;...;<F>;\
        <a>;...;<f>
#
# blank class
#
blank   <space>;<tab>;<b10000>
#
# space class
#
#       space characters in C locale
#

space   <space>;\
        <tab>;\
        <newline>;\
        <vertical-tab>;\
        <form-feed>;\
        <carriage-return>;\
        <b10000>
#
# cntrl class
#
#       same as C locale
# ECU Control Supp C2A1 - C2C1

cntrl   <NUL>;...;<IS1>;\
        <DEL>;\
        <b13300>;...;<b13332>
