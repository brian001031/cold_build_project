<territory>                     "Taiwan"
<modifier>                      "None"

#
#
#       LC_CTYPE
#
#

LC_CTYPE
#
# upper class
#
#       upper case letters in ASCII
#
upper   <A>;...;<Z>
#
# lower class
#
#       lower case letters in ASCII
#
lower   <a>;...;<z>
#
# alpha class
#
#       default to upper and lower
# Frequently used characters  2-byte  (1st  Plane) : C4A1 - FDCB
# Rarely used characters      4-byte  (2nd  Plane) : (8EA2)A1A1 - F2C4
# Rarely used characters      4-byte  (3rd  Plane) : (8EA3)A1A1 - E2C6
# Rarely used characters      4-byte  (4th  Plane) : (8EA4)A1A1 - EEDC
# Rarely used characters      4-byte  (5th  Plane) : (8EA5)A1A1 - FCD1
# Rarely used characters      4-byte  (6th  Plane) : (8EA6)A1A1 - E4FA
# Rarely used characters      4-byte  (7th  Plane) : (8EA7)A1A1 - E6D5
# 8th - 11th Plane are reserved
# User-defined character      4-byte  (12th Plane) : (8EAC)A1A1 - FEFE
# User-defined character      4-byte  (13th Plane) : (8EAD)A1A1 - FEFE
# User-defined character      4-byte  (14th Plane) : (8EAE)A1A1 - FEFE
# User-defined character      4-byte  (15th Plane) : (8EAF)A1A1 - FEFE
# User-defined character      4-byte  (16th Plane) : (8EB0)A1A1 - FEFE

