#

<source_version>      1
<modified_date>       "06/07/1996"
<source_codeset>      "Polish CSK"
<target_codeset>      "Polish Code Page Mazovia"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x80	\x8f        #  latin capital letter a with ogonek 
\x81	\x95        #  latin capital letter c with acute 
\x82	\x90        #  latin capital letter e with ogonek 
\x83	\x9c        #  latin capital letter l with stroke 
\x84	\xa5        #  latin capital letter n with acute 
\x85	\xa3        #  latin capital letter o with acute 
\x86	\x98        #  latin capital letter s with acute 
\x87	\xa0        #  latin capital letter z with acute 
\x88	\xa1        #  latin capital letter z with dot above 
\x8d	\x7f error  #  latin small letter i with grave 
\x8f	\x7f error  #  latin capital letter a with ring above 
\x90	\x7f error  #  latin capital letter e with acute 
\x91	\x7f error  #  latin small letter ae 
\x92	\x7f error  #  latin capital letter ae 
\x95	\x7f error  #  latin small letter o with grave 
\x98	\x7f error  #  latin small letter y with diaeresis 
\x9b	\x7f error  #  cent sign 
\x9c	\x7f error  #  pound sign 
\x9e	\x9b        #  currency sign (Polish) 
\xa0	\x86        #  latin small letter a with ogonek 
\xa1	\x8d        #  latin small letter c with acute 
\xa2	\x91        #  latin small letter e with ogonek 
\xa3	\x92        #  latin small letter l with stroke 
\xa5	\xa2        #  latin small letter o with acute 
\xa6	\x9e        #  latin small letter s with acute 
\xa7	\xa6        #  latin small letter z with acute 
\xa8	\xa7        #  latin small letter z with dot above 
