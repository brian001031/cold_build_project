## space class
##
##	space characters in ASCII and JIS X 0208

space	<tab>;\
	<newline>;\
	<vertical-tab>;\
	<form-feed>;\
	<carriage-return>;\
	<space>;\
	<j0101>

## blank class
##
##	blank characters in ASCII and JIS X 0208

blank	<tab>;\
	<space>;\
	<j0101>

## cntrl class
##
##	cntrl characters in ASCII

cntrl   <NUL>;...;<IS1>;\
	<DEL>

## digit class
##

digit	<zero>;...;<nine>

## xdigit class
##

xdigit	<zero>;...;<nine>;\
	<A>;...;<F>;\
	<a>;...;<f>

