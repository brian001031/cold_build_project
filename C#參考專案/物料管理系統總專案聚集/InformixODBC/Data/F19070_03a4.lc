##
## toupper and tolower
##

toupper	(<a>,<A>);(<b>,<B>);(<c>,<C>);(<d>,<D>);(<e>,<E>);\
	(<f>,<F>);(<g>,<G>);(<h>,<H>);(<i>,<I>);(<j>,<J>);\
	(<k>,<K>);(<l>,<L>);(<m>,<M>);(<n>,<N>);(<o>,<O>);\
	(<p>,<P>);(<q>,<Q>);(<r>,<R>);(<s>,<S>);(<t>,<T>);\
	(<u>,<U>);(<v>,<V>);(<w>,<W>);(<x>,<X>);(<y>,<Y>);\
	(<z>,<Z>)

tolower	(<A>,<a>);(<B>,<b>);(<C>,<c>);(<D>,<d>);(<E>,<e>);\
	(<F>,<f>);(<G>,<g>);(<H>,<h>);(<I>,<i>);(<J>,<j>);\
	(<K>,<k>);(<L>,<l>);(<M>,<m>);(<N>,<n>);(<O>,<o>);\
	(<P>,<p>);(<Q>,<q>);(<R>,<r>);(<S>,<s>);(<T>,<t>);\
	(<U>,<u>);(<V>,<v>);(<W>,<w>);(<X>,<x>);(<Y>,<y>);\
	(<Z>,<z>)


END LC_CTYPE


#############
LC_MONETARY
#############

int_curr_symbol   "<J><P><Y><space>"
currency_symbol   "<yen>"
mon_decimal_point "<period>"
mon_thousands_sep "<comma>"
mon_grouping      3;0
positive_sign     ""
negative_sign     "<hyphen>"
int_frac_digits   0
frac_digits       0
p_cs_precedes     1
p_sep_by_space    0
n_cs_precedes     1
n_sep_by_space    0
p_sign_posn       1
n_sign_posn       4

END LC_MONETARY


#############
LC_NUMERIC
#############

decimal_point     "<period>"
thousands_sep     "<comma>"
grouping          3;0
num_positive_sign ""
num_negative_sign "<hyphen>"

END LC_NUMERIC


#############
LC_TIME
#############

## abday class
##
##	NICHI (Sun), GETSU, KA, SUI, MOKU, KIN, DO in Kanji.

abday	"<j3892>";"<j2378>";"<j1848>";"<j3169>";\
	"<j4458>";"<j2266>";"<j3758>"

## day class
##
##	NICHI-YOUBI (Sunday), GETSU-YOUBI, KA-YOUBI, SUI-YOUBI,
##	MOKU-YOUBI, KIN-YOUBI, DO-YOUBI in Kanji.

day	"<j3892><j4543><j3892>";"<j2378><j4543><j3892>";\
	"<j1848><j4543><j3892>";"<j3169><j4543><j3892>";\
	"<j4458><j4543><j3892>";"<j2266><j4543><j3892>";\
	"<j3758><j4543><j3892>"

## abmon (abbreviated month name) class

abmon   "<J><a><n>";\
	"<F><e><b>";\
	"<M><a><r>";\
	"<A><p><r>";\
	"<M><a><y>";\
	"<J><u><n>";\
	"<J><u><l>";\
	"<A><u><g>";\
	"<S><e><p>";\
	"<O><c><t>";\
	"<N><o><v>";\
	"<D><e><c>"

## mon (full month name) class

mon     "<J><a><n><u><a><r><y>";\
	"<F><e><b><r><u><a><r><y>";\
	"<M><a><r><c><h>";\
	"<A><p><r><i><l>";\
	"<M><a><y>";\
	"<J><u><n><e>";\
	"<J><u><l><y>";\
	"<A><u><g><u><s><t>";\
	"<S><e><p><t><e><m><b><e><r>";\
	"<O><c><t><o><b><e><r>";\
	"<N><o><v><e><m><b><e><r>";\
	"<D><e><c><e><m><b><e><r>"

## era (Era year) class
##
##	HEISEI, SHOWA, TAISHO, MEIJI.
##	Years befor MEIJI are printed as SEIREKI (A.D.) or KIGENZEN (B.C.).
##
##   format
##	direction:offset:start_date:end_date:era_name:abbr_era_name:era_format
## 
##   where
##	direction      is either + or -
##	offset         is an integer
##	start date     is a date represented by YYYY/MM/DD
##	end_date       is a date represented by YYYY/MM/DD or one of
##	               +* (for end of time) or -* (for beginning of time).
##	era_name       is a multi-byte string
##	abbr_era_name  is a multi-byte string
##	era_format     is a format specification

era	"<plus-sign><colon><two><colon>\
	<one><nine><nine><zero><slash><zero><one><slash><zero><one><colon>\
	<plus-sign><asterisk><colon>\
	<j4231><j3214><colon><H><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>";\
	"<plus-sign><colon><one><colon>\
	<one><nine><eight><nine><slash><zero><one><slash><zero><eight><colon>\
	<one><nine><eight><nine><slash><one><two><slash><three><one><colon>\
	<j4231><j3214><colon><H><colon>\
	<percent-sign><E><C><j2421><j3915>";\
	"<plus-sign><colon><two><colon>\
	<one><nine><two><seven><slash><zero><one><slash><zero><one><colon>\
	<one><nine><eight><nine><slash><zero><one><slash><zero><seven><colon>\
	<j3028><j4734><colon><S><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>";\
	"<plus-sign><colon><one><colon>\
	<one><nine><two><six><slash><one><two><slash><two><five><colon>\
	<one><nine><two><six><slash><one><two><slash><three><one><colon>\
	<j3028><j4734><colon><S><colon>\
	<percent-sign><E><C><j2421><j3915>";\
	"<plus-sign><colon><two><colon>\
	<one><nine><one><three><slash><zero><one><slash><zero><one><colon>\
	<one><nine><two><six><slash><one><two><slash><two><four><colon>\
	<j3471><j3221><colon><T><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>";\
	"<plus-sign><colon><one><colon>\
	<one><nine><one><two><slash><zero><seven><slash><three><zero><colon>\
	<one><nine><one><two><slash><one><two><slash><three><one><colon>\
	<j3471><j3221><colon><T><colon>\
	<percent-sign><E><C><j2421><j3915>";\
	"<plus-sign><colon><two><colon>\
	<one><eight><six><nine><slash><zero><one><slash><zero><one><colon>\
	<one><nine><one><two><slash><zero><seven><slash><two><nine><colon>\
	<j4432><j2803><colon><M><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>";\
	"<plus-sign><colon><one><colon>\
	<one><eight><six><eight><slash><zero><nine><slash><zero><eight><colon>\
	<one><eight><six><eight><slash><one><two><slash><three><one><colon>\
	<j4432><j2803><colon><M><colon>\
	<percent-sign><E><C><j2421><j3915>";\
	"<plus-sign><colon><one><colon>\
	<zero><zero><zero><one><slash><zero><one><slash><zero><one><colon>\
	<one><eight><six><eight><slash><zero><nine><slash><zero><seven><colon>\
	<j3230><j4681><colon><A><period><D><period><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>";\
	"<hyphen><colon><one><colon>\
	<hyphen><zero><zero><zero><one><slash>\
	<one><two><slash><three><one><colon>\
	<hyphen><asterisk><colon>\
	<j2110><j2421><j3316><colon><B><period><C><period><colon>\
	<percent-sign><E><C><percent-sign><E><y><j3915>"

## d_t_fmt class
##
##	appropriate date and time representation, corresponding to "%c"

d_t_fmt	"<percent-sign><Y><j3915>\
	<percent-sign><m><j2378>\
	<percent-sign><d><j3892><space>\
	<left-parenthesis><percent-sign><a><right-parenthesis><space>\
	<percent-sign><H><j2794>\
	<percent-sign><M><j4212>\
	<percent-sign><S><j4135>"

## d_fmt class
##
##	%Y/%m/%d (1995/08/28)

d_fmt	"<percent-sign><i><Y><slash><percent-sign><m><slash><percent-sign><d>"

## t_fmt class
##
##	%H:%M:%S (9:45:00)

t_fmt	"<percent-sign><H><colon><percent-sign><M><colon><percent-sign><S>"

## am_pm class
##
##	GOZEN and GOGO in Kanji

am_pm	"<j2465><j3316>";"<j2465><j2469>"

## t_fmt_ampm class

t_fmt_ampm	"<percent-sign><p>\
		 <percent-sign><I><j2794>\
		 <percent-sign><M><j4212>\
		 <percent-sign><S><j4135>"

## era_d_fmt class

era_d_fmt	"<percent-sign><E><Y>\
		<percent-sign><m><j2378><percent-sign><d><j3892>"

## era_t_fmt class

era_t_fmt	"<percent-sign><H><j2794>\
		<percent-sign><M><j4212><percent-sign><S><j4135>"


## era_d_t_fmt class

era_d_t_fmt	"<percent-sign><E><Y>\
		<percent-sign><m><j2378>\
		<percent-sign><d><j3892><space>\
		<left-parenthesis><percent-sign><a><right-parenthesis><space>\
		<percent-sign><H><j2794>\
		<percent-sign><M><j4212>\
		<percent-sign><S><j4135>"

END LC_TIME


#############
LC_MESSAGES
#############

yesexpr "<circumflex-accent><left-parenthesis><left-square-bracket><less-than-sign><y><greater-than-sign><less-than-sign><Y><greater-than-sign><right-square-bracket><vertical-line><left-square-bracket><less-than-sign><y><greater-than-sign><less-than-sign><Y><greater-than-sign><right-square-bracket><left-square-bracket><less-than-sign><e><greater-than-sign><less-than-sign><E><greater-than-sign><right-square-bracket><left-square-bracket><less-than-sign><s><greater-than-sign><less-than-sign><S><greater-than-sign><right-square-bracket><right-parenthesis>"
noexpr  "<circumflex-accent><left-parenthesis><left-square-bracket><less-than-sign><n><greater-than-sign><less-than-sign><N><greater-than-sign><right-square-bracket><vertical-line><left-square-bracket><less-than-sign><n><greater-than-sign><less-than-sign><N><greater-than-sign><right-square-bracket><left-square-bracket><less-than-sign><o><greater-than-sign><less-than-sign><O><greater-than-sign><right-square-bracket><right-parenthesis>"

END LC_MESSAGES
