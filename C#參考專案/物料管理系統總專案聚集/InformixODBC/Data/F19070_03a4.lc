## upper class
##
##	upper case letters in ASCII and JIS X 0208

upper	<A>;...;<Z>;\
	<j0333>;...;<j0358>;\
	<j0601>;...;<j0624>;\
	<j0701>;...;<j0733>

## lower class
##
##	lower case letters in ASCII and JIS X 0208

lower	<a>;...;<z>;\
	<j0365>;...;<j0390>;\
	<j0633>;...;<j0656>;\
	<j0749>;...;<j0763>;\
	<j0764>;...;<j0781>

## alpha class
##
##	default to upper and lower
##	and
##	Kana                      in JIS X 0201,
##	Hiragana, Katakana, Kanji in JIS X 0208,
##	Number                    in JIS X 0208,
##	Level 1 and 2 Kanji       in JIS X 0208.
##

alpha	<kana_WO>;...;<kana_tsu>;\
	<prolongedsound>;\
	<kana_A>;...;<kana_N>;\
	<voicedsound>;<semivoicedsound>;\
# JIS X 0208
#  Special Hiragana and Katakana and Kanji.
	<j0111>;<j0112>;\
	<j0119>;...;<j0128>;\
#  Number (0-9)
	<j0316>;...;<j0325>;\
#  Hiragana
	<j0401>;...;<j0483>;\
