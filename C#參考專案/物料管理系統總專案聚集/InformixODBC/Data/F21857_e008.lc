#
# digit class
#
digit   <zero>;...;<nine>

#
# xdigit class
#
xdigit  <zero>;...;<nine>;\
        <A>;...;<F>;\
        <a>;...;<f>
#
# blank class
#
blank   <tab>;<space>;<ixtw10000>
#
# space class
#
#       space characters in C locale
#
space   <tab>;\
        <newline>;\
        <vertical-tab>;\
        <form-feed>;\
        <carriage-return>;\
        <space>;\
        <ixtw10000>
#
# cntrl class
#
#       same as C locale
# Big5 Control Supp a3c0 - a3e0, a3e1 - a3fe
#
cntrl   <NUL>;...;<IS1>;\
        <DEL>;\
        <ixtw20231>;...;<ixtw20293>
#
# punct class
#
# Big5 Special Fonts a140 - a3bf
#
punct   <exclamation-mark>;...;<slash>;\
        <colon>;...;<commercial-at>;\
        <left-square-bracket>;...;<grave-accent>;\
        <left-brace>;...;<tilde>;\
        <ixtw10001>;...;<ixtw10062>;\
        <ixtw10100>;...;<ixtw10162>;\
# 	Note: ixtw10200 to ixtw10203 are two-byte w to z 
        <ixtw10204>;...;<ixtw10262>;\
        <ixtw20000>;...;<ixtw20035>;\
# 	Note: ixtw20036 (a1c5?) is allegedly the two-byte underscore character
#       <two-byte-underscore>.  This should be classified as 'alpha' so
# 	that it is valid in identifiers.  However, there is currently some
#       confusion about whether a1c5 is the correct encoding.  ixtw20036 is 
#       currently classified as punct until this is resolved.
        <ixtw20036>;\
        <ixtw20037>;...;<ixtw20093>;\
        <ixtw20100>;...;<ixtw20113>;\
# 	Note: ixtw20114 to ixtw20123 are two-byte 0 to 9 
        <ixtw20124>;...;<ixtw20145>;\
# 	Note: ixtw20146 to ixtw20171 are two-byte A to Z 
# 	Note: ixtw20172 to ixtw20193 are two-byte a to v 
        <ixtw20200>;...;<ixtw20230>

#
# graph
#
#       upper, lower, alpha, digit, xdigit
# Big5 Special Fonts a140 - a3bf
# Frequently used character A440 - C67E
# Rarely used characters c940 - f9d5
# User-defined characters and round-trip placeholders
#
graph   <exclamation-mark>;...;<tilde>;\
        <ixtw10001>;...;<ixtw10062>;\
        <ixtw10100>;...;<ixtw10162>;\
        <ixtw10200>;...;<ixtw10262>;\
