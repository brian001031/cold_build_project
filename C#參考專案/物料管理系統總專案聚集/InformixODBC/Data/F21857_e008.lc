#
#  Title:      Big Five locale
#  Sccsid:
#  Description:
#
#              Big Five locale description for GLS library.
#              This locale is based on the X/Open definition.
#
#  Modification:
#              rhuang@informix.com Mon Aug 7 17:15:19 TWN 1995
#              -   Provide display width extension for multibyte characters.
#              pstephen 11 Dec 1996
#              -   Removed LC_COLLATE section.  Defining collation for a 
#              only some characters caused all others to collate with zero
#	       weight.  No LC_COLLATE section means codeset order collation.
#              pstephen 23 Jan 1997
#              -   Added two-byte versions of digits 0-9 and
#	       letters A-Z and a-z, to appropriate categories so they
#	       can be used as identifiers.  Previously they were 
#	       classified as punctuation.
#	       - Also added num_positive_sign definition (empty)
#
###########################################################################

<source_version>                4
<modified_date>                 "01/DEC/99"
<language>                      "Chinese"
<territory>                     "Taiwan"
<modifier>                      "None"

#
#
#       LC_CTYPE
#
#

LC_CTYPE
#
# upper class
#
#       upper case letters in ASCII
# 	two-byte A...Z at a2cf...a2e8 inclusive
#
upper   <A>;...;<Z>;\
        <two-byte-A>;...;<two-byte-Z>
#
#
#
#
# lower class
#
#       lower case letters in ASCII
# 	two-byte a...v at a2e9...a2fe inclusive 
# 	two-byte w...z at a340...a343 inclusive 
#
lower   <a>;...;<z>;\
        <two-byte-a>;...;<two-byte-v>;\
        <two-byte-w>;...;<two-byte-z>
#
# alpha class
#
#       default to upper and lower
# Frequently used characters \xa4\x40 - \xc6\x7e
# Rarely used characters \xc9\x40 - \xf9\xd5, supplement \xf9\xd6 - \xf9\xfe
# User-defined characters
#
alpha   <A>;...;<Z>;\
        <a>;...;<z>;\
#
# 	two-byte 0...9 at a2af...a2b8 inclusive 
#    		nb two byte 0..9 classified as 'alpha' -- cannot classify 
#    		alternative digits in 'digit' category.
# 	two-byte A...Z at a2cf...a2e8 inclusive
# 	two-byte a...v at a2e9...a2fe inclusive 
# 	two-byte w...z at a340...a343 inclusive 
        <two-byte-0>;...;<two-byte-9>;\
        <two-byte-A>;...;<two-byte-Z>;\
        <two-byte-a>;...;<two-byte-v>;\
        <two-byte-w>;...;<two-byte-z>;\
#
# 	two-byte version of underscore (a1c5?) classified as 'alpha' so 
# 	that it is valid in identifiers.
#       Currently commented out since it is not clear what is the correct
#       codepoint for this character.  It has been left in the 'punct'
#       category instead until this issue is resolved.
#       <two-byte-underscore>;\
#
        <ixtw10300>;...;<ixtw10362>;\
        <ixtw10400>;...;<ixtw10462>;\
        <ixtw10500>;...;<ixtw10562>;\
        <ixtw10600>;...;<ixtw10662>;\
