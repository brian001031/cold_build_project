#############
LC_MONETARY
#############

int_curr_symbol   "<D><K><K><space>"
currency_symbol   "<k><r>"
mon_decimal_point "<comma>"
mon_thousands_sep "<period>"
mon_grouping      3
positive_sign     ""
negative_sign     "<hyphen>"
int_frac_digits   2
frac_digits       2
p_cs_precedes     1
p_sep_by_space    1
n_cs_precedes     1
n_sep_by_space    1
p_sign_posn       4
n_sign_posn       4

END LC_MONETARY


#############
LC_NUMERIC
#############

decimal_point     "<comma>"
thousands_sep     "<period>" 
grouping          3

num_positive_sign	""
num_negative_sign	"<hyphen>"

END LC_NUMERIC


#############
LC_TIME
#############
abday   "<S><o-slash><n>";\
	"<M><a><n>";\
	"<T><i><r>";\
	"<O><n><s>";\
	"<T><o><r>";\
	"<F><r><e>";\
	"<L><o-slash><r>"

day     "<S><o-slash><n><d><a><g>";\
	"<M><a><n><d><a><g>";\
	"<T><i><r><s><d><a><g>";\
	"<O><n><s><d><a><g>";\
	"<T><o><r><s><d><a><g>";\
	"<F><r><e><d><a><g>";\
	"<L><o-slash><r><d><a><g>"

abmon   "<J><a><n>";\
	"<F><e><b>";\
	"<M><a><r>";\
	"<A><p><r>";\
	"<M><a><j>";\
	"<J><u><n>";\
	"<J><u><l>";\
	"<A><u><g>";\
	"<S><e><p>";\
	"<O><k><t>";\
	"<N><o><v>";\
	"<D><e><c>"

mon     "<J><a><n><u><a><r>";\
	"<F><e><b><r><u><a><r>";\
	"<M><a><r><t><s>";\
	"<A><p><r><i><l>";\
	"<M><a><j>";\
	"<J><u><n><i>";\
	"<J><u><l><i>";\
	"<A><u><g><u><s><t>";\
	"<S><e><p><t><e><m><b><e><r>";\
	"<O><k><t><o><b><e><r>";\
	"<N><o><v><e><m><b><e><r>";\
	"<D><e><c><e><m><b><e><r>"

d_t_fmt "<percent-sign><a><period><space><percent-sign><period>\
	<one><d><space><percent-sign><b><period><space><percent-sign>\
	<i><Y><space><percent-sign><H><colon><percent-sign><M>"

d_fmt   "<percent-sign><i><Y><hyphen><percent-sign><m>\
	<hyphen><percent-sign><d>"

t_fmt   "<percent-sign><H><colon><percent-sign><M><colon><percent-sign><S>"

t_fmt_ampm	""

am_pm   "<space>";"<space>"

END LC_TIME


#############
LC_MESSAGES
#############

# The ISO-7-Danish codeset doesn't contain circumflex or square-bracket
# or vertical-line, so regular expressions cannot be used.

yesexpr "<j><a>"
noexpr  "<n><e><j>"

END LC_MESSAGES
