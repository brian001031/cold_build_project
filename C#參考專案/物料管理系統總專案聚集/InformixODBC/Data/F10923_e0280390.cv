\x9d	\x1a error  #  yen sign 
\x9e	\xb6        #  latin small letter s with acute 
\x9f	\x1a error  #  dutch guilder sign (ibm437 159) 
\xa0	\xac        #  latin capital letter z with acute 
\xa1	\xaf        #  latin capital letter z with dot above 
\xa2	\xf3        #  latin small letter o with acute 
\xa3	\xd3        #  latin capital letter o with acute 
