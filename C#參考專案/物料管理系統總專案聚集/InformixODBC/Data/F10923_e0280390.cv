#  Title:       e0280390.cm
#  Author:      Informix ELC
#  Created:     Wed May 22 16:29:23 1996
#  Description:
#    Conversion file from Polish Code Page Mazovia to ISO Code Page 8859-2
#    Registry value (Decimal):  From 57384 to 912
#    Registry value (Hex): From e028 to 0390
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x1a and lossy conversion error
#    is generated.
#
#*************************************************************************
#

<source_version>      1
<modified_date>       "06/07/1996"
<source_codeset>      "Polish Code Page Mazovia"
<target_codeset>      "ISO Code Page 8859-2"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x80	\xc7        #  latin capital letter c with cedilla 
\x81	\xfc        #  latin small letter u with diaeresis 
\x82	\xe9        #  latin small letter e with acute 
\x83	\xe2        #  latin small letter a with circumflex 
\x84	\xe4        #  latin small letter a with diaeresis 
\x85	\x1a error  #  latin small letter a with grave 
\x86	\xb1        #  latin small letter a with ogonek 
\x87	\xe7        #  latin small letter c with cedilla 
\x88	\x1a error  #  latin small letter e with circumflex 
\x89	\xeb        #  latin small letter e with diaeresis 
\x8a	\x1a error  #  latin small letter e with grave 
\x8b	\x1a error  #  latin small letter i with diaeresis 
\x8c	\xee        #  latin small letter i with circumflex 
\x8d	\xe6        #  latin small letter c with acute 
\x8e	\xc4        #  latin capital letter a with diaeresis 
\x8f	\xa1        #  latin capital letter a with ogonek 
\x90	\xca        #  latin capital letter e with ogonek 
\x91	\xea        #  latin small letter e with ogonek 
\x92	\xb3        #  latin small letter l with stroke 
\x93	\xf4        #  latin small letter o with circumflex 
\x94	\xf6        #  latin small letter o with diaeresis 
\x95	\xc6        #  latin capital letter c with acute 
\x96	\x1a error  #  latin small letter u with circumflex 
\x97	\x1a error  #  latin small letter u with grave 
\x98	\xa6        #  latin capital letter s with acute 
\x99	\xd6        #  latin capital letter o with diaeresis 
\x9a	\xdc        #  latin capital letter u with diaeresis 
\x9b	\x1a error  #  currency sign (Polish) 
