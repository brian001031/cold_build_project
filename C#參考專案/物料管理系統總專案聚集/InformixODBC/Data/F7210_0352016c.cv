#  Title:       0352016c.cm
#  Author:      Informix ELC
#  Created:     Fri Jun 07 12:31:30 1996
#  Description:
#    Conversion file from IBM Code Page 850 to ASCII 7-Bit
#    Registry value (Decimal):  From 850 to 364
#    Registry value (Hex): From 0352 to 016c
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x7f and lossy conversion error
#    is generated.
#
#*************************************************************************
#

<source_version>      1
<modified_date>       "06/07/1996"
<source_codeset>      "IBM Code Page 850"
<target_codeset>      "ASCII 7-Bit"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x80	\x7f error  #  latin capital letter c with cedilla 
\x81	\x7f error  #  latin small letter u with diaeresis 
\x82	\x7f error  #  latin small letter e with acute 
\x83	\x7f error  #  latin small letter a with circumflex 
\x84	\x7f error  #  latin small letter a with diaeresis 
