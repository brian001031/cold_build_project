#  Title:       035404e2.cv
#  Author:      Informix ELC
#  Created:     Tue Jan 28 10:49:53 1997
#  Description:
#    Conversion file from IBM Code Page 852 to Windows Code Page 1250
#    Registry value (Decimal):  From 852 to 1250
#    Registry value (Hex): From 0354 to 04e2
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x7f and lossy conversion error
#    is generated.
#
#*************************************************************************
#

<source_version>      2
<modified_date>       "01/28/1997"
<source_codeset>      "IBM Code Page 852"
<target_codeset>      "Windows Code Page 1250"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x80	\xc7        #  latin capital letter c with cedilla 
