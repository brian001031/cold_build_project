	<N-acute>;\
	<greek-GAMMA>;\
	<greek-SIGMA>;\
	<greek-PHI>;\
	<greek-THETA>;\
	<greek-OMEGA>


lower   <a>;...;<z>;\
	<u-diaeresis>;\
	<e-acute>;\
	<a-circumflex>;\
	<a-diaeresis>;\
	<a-grave>;\
	<a-ogonek>;\
	<c-cedilla>;\
	<e-circumflex>;\
	<e-diaeresis>;\
	<e-grave>;\
	<i-diaeresis>;\
	<i-circumflex>;\
	<c-acute>;\
	<e-ogonek>;\
	<l-stroke>;\
	<o-circumflex>;\
	<o-diaeresis>;\
	<u-circumflex>;\
	<u-grave>;\
	<s-acute>;\
	<o-acute>;\
	<n-acute>;\
	<z-acute>;\
	<z-dot-above>;\
	<greek-alpha>;\
	<greek-beta>;\
	<greek-pi>;\
	<greek-sigma>;\
	<greek-mu>;\
	<greek-tau>;\
	<greek-delta>;\
	<greek-epsilon>


space  	<tab>;\
	<newline>;\
	<vertical-tab>;\
       	<form-feed>;\
	<carriage-return>;\
	<space>

cntrl  	<NUL>;...;<IS1>;\
	<DEL>

graph	<exclamation-mark>;...;<tilde>;\
	<C-cedilla>;...;<boxfill-middle>

print	<space>;...;<tilde>;\
	<C-cedilla>;...;<nobreakspace>

punct  	<exclamation-mark>;...;<slash>;\
        <colon>;...;<commercial-at>;\
        <left-square-bracket>;...;<grave-accent>;\
        <left-brace>;...;<tilde>;\
        <currency-sign-polish>;\
        <yen>;\
        <florin>;\
        <question-down>;...;<upper-half-block>;\
        <infinity>;\
        <empty-set>;\
        <intersection>;...;<boxfill-middle>

digit  	<zero>;...;<nine>

xdigit 	<zero>;...;<nine>;\
	<A>;...;<F>;\
	<a>;...;<f>

blank  	<space>;\
	<tab>;\
	<nobreakspace>


toupper (<a>,<A>);(<b>,<B>);(<c>,<C>);(<d>,<D>);(<e>,<E>);\
        (<f>,<F>);(<g>,<G>);(<h>,<H>);(<i>,<I>);(<j>,<J>);\
        (<k>,<K>);(<l>,<L>);(<m>,<M>);(<n>,<N>);(<o>,<O>);\
        (<p>,<P>);(<q>,<Q>);(<r>,<R>);(<s>,<S>);(<t>,<T>);\
        (<u>,<U>);(<v>,<V>);(<w>,<W>);(<x>,<X>);(<y>,<Y>);\
        (<z>,<Z>);\
	(<a-diaeresis>,<A-diaeresis>);\
	(<a-ogonek>,<A-ogonek>);\
	(<c-acute>,<C-acute>);\
	(<c-cedilla>,<C-cedilla>);\
	(<e-ogonek>,<E-ogonek>);\
	(<s-acute>,<S-acute>);\
	(<o-diaeresis>,<O-diaeresis>);\
	(<u-diaeresis>,<U-diaeresis>);\
	(<l-stroke>,<L-stroke>);\
	(<z-acute>,<Z-acute>);\
	(<z-dot-above>,<Z-dot-above>);\
	(<o-acute>,<O-acute>);\
	(<n-acute>,<N-acute>);\
	(<greek-sigma>,<greek-SIGMA>)

tolower (<A>,<a>);(<B>,<b>);(<C>,<c>);(<D>,<d>);(<E>,<e>);\
        (<F>,<f>);(<G>,<g>);(<H>,<h>);(<I>,<i>);(<J>,<j>);\
        (<K>,<k>);(<L>,<l>);(<M>,<m>);(<N>,<n>);(<O>,<o>);\
        (<P>,<p>);(<Q>,<q>);(<R>,<r>);(<S>,<s>);(<T>,<t>);\
        (<U>,<u>);(<V>,<v>);(<W>,<w>);(<X>,<x>);(<Y>,<y>);\
        (<Z>,<z>);\
	(<A-diaeresis>,<a-diaeresis>);\
	(<A-ogonek>,<a-ogonek>);\
	(<C-acute>,<c-acute>);\
	(<C-cedilla>,<c-cedilla>);\
	(<E-ogonek>,<e-ogonek>);\
	(<S-acute>,<s-acute>);\
	(<O-diaeresis>,<o-diaeresis>);\
	(<U-diaeresis>,<u-diaeresis>);\
	(<L-stroke>,<l-stroke>);\
	(<Z-acute>,<z-acute>);\
	(<Z-dot-above>,<z-dot-above>);\
	(<O-acute>,<o-acute>);\
	(<N-acute>,<n-acute>);\
	(<greek-SIGMA>,<greek-sigma>)

END LC_CTYPE




