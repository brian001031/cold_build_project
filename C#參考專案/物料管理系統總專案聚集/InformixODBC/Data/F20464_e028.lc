#############
LC_CTYPE
#############

upper   <A>;...;<Z>;\
	<C-cedilla>;\
	<A-diaeresis>;\
	<A-ogonek>;\
	<E-ogonek>;\
	<C-acute>;\
	<S-acute>;\
	<O-diaeresis>;\
	<U-diaeresis>;\
	<L-stroke>;\
	<Z-acute>;\
