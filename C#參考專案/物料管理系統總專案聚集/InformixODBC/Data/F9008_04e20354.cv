#  Title:       04e20354.cv
#  Author:      Informix ELC
#  Created:     Tue Jan 28 10:48:35 1997
#  Description:
#    Conversion file from Windows Code Page 1250 to IBM Code Page 852
#    Registry value (Decimal):  From 1250 to 852
#    Registry value (Hex): From 04e2 to 0354
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x7f and lossy conversion error
#    is generated.
#
#*************************************************************************
#

<source_version>      2
<modified_date>       "01/28/1997"
<source_codeset>      "Windows Code Page 1250"
<target_codeset>      "IBM Code Page 852"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x82	\x7f error  #  single low-9 quotation mark 
\x84	\x7f error  #  double low-9 quotation mark 
\x85	\x7f error  #  midline horizontal ellipsis 
\x86	\x7f error  #  dagger 
\x87	\x7f error  #  double dagger 
\x89	\x7f error  #  per mille sign 
\x8a	\xe6        #  latin capital letter s with caron 
\x8b	\x7f error  #  single left-pointing angle quotation mark 
\x8c	\x97        #  latin capital letter s with acute 
\x8d	\x9b        #  latin capital letter t with caron 
\x8e	\xa6        #  latin capital letter z with caron 
\x8f	\x8d        #  latin capital letter z with acute 
\x91	\x7f error  #  left single quotation mark 
\x92	\x7f error  #  right single quotation mark 
\x93	\x7f error  #  left double quotation mark 
\x94	\x7f error  #  right double quotation mark 
\x95	\x7f error  #  bullet operator 
\x96	\x7f error  #  en dash 
\x97	\x7f error  #  em dash 
\x99	\x7f error  #  trade mark sign 
\x9a	\xe7        #  latin small letter s with caron 
\x9b	\x7f error  #  single right-pointing angle quotation mark 
\x9c	\x98        #  latin small letter s with acute 
\x9d	\x9c        #  latin small letter t with caron 
\x9e	\xa7        #  latin small letter z with caron 
\x9f	\xab        #  latin small letter z with acute 
\xa0	\xff        #  no-break space 
\xa1	\xf3        #  caron 
\xa2	\xf4        #  breve 
\xa3	\x9d        #  latin capital letter l with stroke 
\xa4	\xcf        #  currency sign 
\xa5	\xa4        #  latin capital letter a with ogonek 
\xa6	\x7f error  #  broken bar 
\xa7	\xf5        #  section sign 
\xa8	\xf9        #  diaeresis 
\xa9	\x7f error  #  copyright sign 
\xaa	\xb8        #  latin capital letter s with cedilla 
\xab	\xae        #  left-pointing double angle quotation mark 
\xac	\xaa        #  not sign 
\xad	\xf0        #  soft hyphen 
\xae	\x7f error  #  registered sign 
\xaf	\xbd        #  latin capital letter z with dot above 
\xb0	\xf8        #  degree sign 
\xb1	\x7f error  #  plus-minus sign 
\xb2	\xf2        #  ogonek 
\xb3	\x88        #  latin small letter l with stroke 
\xb4	\xef        #  acute accent 
\xb5	\x7f error  #  micro sign 
