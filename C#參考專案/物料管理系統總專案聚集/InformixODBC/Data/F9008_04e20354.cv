\xb7	\x7f error  #  middle dot 
\xb8	\xf7        #  cedilla 
\xb9	\xa5        #  latin small letter a with ogonek 
\xba	\xad        #  latin small letter s with cedilla 
\xbb	\xaf        #  right-pointing double angle quotation mark 
\xbc	\x95        #  latin capital letter l with caron 
\xbd	\xf1        #  double acute accent 
\xbe	\x96        #  latin small letter l with caron 
\xbf	\xbe        #  latin small letter z with dot above 
\xc0	\xe8        #  latin capital letter r with acute 
