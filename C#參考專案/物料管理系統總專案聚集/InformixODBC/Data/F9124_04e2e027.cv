\xa7	\x7f error  #  section sign 
\xa8	\x7f error  #  diaeresis 
\xa9	\x7f error  #  copyright sign 
\xaa	\x7f error  #  latin capital letter s with cedilla 
\xab	\xae        #  left-pointing double angle quotation mark 
