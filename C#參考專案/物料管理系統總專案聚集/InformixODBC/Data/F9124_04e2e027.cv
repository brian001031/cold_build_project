#  Description:
#    Conversion file from Windows Code Page 1250 to Polish CSK
#    Registry value (Decimal):  From 1250 to 57383
#    Registry value (Hex): From 04e2 to e027
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x7f and lossy conversion error
#    is generated.
#
#*************************************************************************
#

<source_version>      1
<modified_date>       "06/07/1996"
<source_codeset>      "Windows Code Page 1250"
<target_codeset>      "Polish CSK"

# Conversion Table
\x00...\xff \x00... #  Default everything onto itself
\x82	\x7f error  #  single low-9 quotation mark 
\x84	\x7f error  #  double low-9 quotation mark 
\x85	\x7f error  #  midline horizontal ellipsis 
\x86	\x7f error  #  dagger 
\x87	\x7f error  #  double dagger 
\x89	\x7f error  #  per mille sign 
\x8a	\x7f error  #  latin capital letter s with caron 
\x8b	\x7f error  #  single left-pointing angle quotation mark 
\x8c	\x86        #  latin capital letter s with acute 
\x8d	\x7f error  #  latin capital letter t with caron 
\x8e	\x7f error  #  latin capital letter z with caron 
\x8f	\x87        #  latin capital letter z with acute 
\x91	\x7f error  #  left single quotation mark 
\x92	\x7f error  #  right single quotation mark 
\x93	\x7f error  #  left double quotation mark 
\x94	\x7f error  #  right double quotation mark 
\x95	\xfa        #  bullet operator 
\x96	\x7f error  #  en dash 
\x97	\x7f error  #  em dash 
\x99	\x7f error  #  trade mark sign 
\x9a	\x7f error  #  latin small letter s with caron 
\x9b	\x7f error  #  single right-pointing angle quotation mark 
\x9c	\xa6        #  latin small letter s with acute 
\x9d	\x7f error  #  latin small letter t with caron 
\x9e	\x7f error  #  latin small letter z with caron 
\x9f	\xa7        #  latin small letter z with acute 
\xa0	\xff        #  no-break space 
\xa1	\x7f error  #  caron 
