#  Title:       03f30333.cv
#  Author:      John Griffin
#  Created:     Thu Jul 27 15:46:17 1995
#  Description:
#    Conversion file from 646de to 8859-1
#    Registry values (Decimal): From 1011 to 819
#    Registry values (Hex): From 03f3 to 0333
#
#    This conversion uses enforced subset criteria-all unmappable characters
#    are mapped to the SUB character \x1a and lossy conversion error
#    is generated.
#
#**************************************************************************
#
<source_version>    1
<modified_date>     "07/27/1995"
<source_codeset>    "646de"
<target_codeset>    "8859-1"

\x00...\xff	\x00...	# Default everything onto itself
\x40	\xa7		# section sign 
\x5b	\xc4		# latin capital letter a with diaeresis 
\x5c	\xd6		# latin capital letter o with diaeresis 
\x5d	\xdc		# latin capital letter u with diaeresis 
\x7b	\xe4		# latin small letter a with diaeresis 
\x7c	\xf6		# latin small letter o with diaeresis 
\x7d	\xfc		# latin small letter u with diaeresis 
\x7e	\xdf		# latin small letter sharp s (german) 
