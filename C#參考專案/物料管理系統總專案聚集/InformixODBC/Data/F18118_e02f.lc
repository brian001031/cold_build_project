LC_TIME
#############
abday   "<D><i><m>";\
	"<L><u><n>";\
	"<M><a><r>";\
	"<M><e><r>";\
	"<J><e><u>";\
	"<V><e><n>";\
	"<S><a><m>"

day     "<D><i><m><a><n><c><h><e>";\
	"<L><u><n><d><i>";\
	"<M><a><r><d><i>";\
	"<M><e><r><c><r><e><d><i>";\
	"<J><e><u><d><i>";\
	"<V><e><n><d><r><e><d><i>";\
	"<S><a><m><e><d><i>"

abmon   "<J><a><n>";\
	"<F><e-acute><v>";\
	"<M><a><r>";\
	"<A><v><r>";\
	"<M><a><i>";\
	"<J><u><n>";\
	"<J><u><l>";\
	"<A><o><u-circumflex>";\
	"<S><e><p>";\
	"<O><c><t>";\
	"<N><o><v>";\
	"<D><e-acute><c>"

mon     "<J><a><n><v><i><e><r>";\
	"<F><e-acute><v><r><i><e><r>";\
	"<M><a><r><s>";\
	"<A><v><r><i><l>";\
	"<M><a><i>";\
	"<J><u><i><n>";\
	"<J><u><i><l><l><e><t>";\
	"<A><o><u-circumflex><t>";\
	"<S><e><p><t><e><m><b><r><e>";\
	"<O><c><t><o><b><r><e>";\
	"<N><o><v><e><m><b><r><e>";\
	"<D><e-acute><c><e><m><b><r><e>"

d_t_fmt "<percent-sign><a><space><percent-sign><e><space><percent-sign><b><space><percent-sign><H><colon><percent-sign><M><colon><percent-sign><S><space><percent-sign><i><Y>"

d_fmt   "<percent-sign><d><full-stop><percent-sign><m><full-stop><percent-sign><i><y>"

t_fmt   "<percent-sign><H><colon><percent-sign><M><colon><percent-sign><S>"


t_fmt_ampm	""


am_pm   "<space>";"<space>"

END LC_TIME


#############
LC_MESSAGES
#############

yesexpr "<circumflex-accent><left-parenthesis><left-square-bracket><o><O><right-square-bracket><vertical-line><left-square-bracket><o><O><right-square-bracket><left-square-bracket><u><U><right-square-bracket><left-square-bracket><i><I><right-square-bracket><right-parenthesis>"
noexpr  "<circumflex-accent><left-parenthesis><left-square-bracket><n><N><right-square-bracket><vertical-line><left-square-bracket><n><N><right-square-bracket><left-square-bracket><o><O><right-square-bracket><left-square-bracket><n><N><right-square-bracket><right-parenthesis>"

END LC_MESSAGES
